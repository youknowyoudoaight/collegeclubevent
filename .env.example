# ── Local development ──────────────────────────────────
SECRET_KEY=change_this_to_a_long_random_string
FLASK_DEBUG=true

# Generic DB vars (local dev)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=club_events_db

# ── Railway auto-injects these when you add MySQL plugin ──
# (you do NOT need to set these manually on Railway)
# MYSQLHOST=...
# MYSQLPORT=...
# MYSQLUSER=...
# MYSQLPASSWORD=...
# MYSQLDATABASE=...
